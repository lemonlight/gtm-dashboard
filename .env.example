# Amplitude (Settings → Projects → API Key / Secret Key)
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# Stripe (Developers → API Keys — use a restricted read-only key)
STRIPE_SECRET_KEY=

# MongoDB Atlas (Connect → connection string — use a read-only user)
MONGODB_URI=

# Dashboard password (shared password for HTTP Basic Auth)
DASHBOARD_PASSWORD=
